# ---- Database: Supabase Postgres ----
# Local dev: run `npx supabase start` (Docker), then use its DB URL (default below).
# Studio UI is at http://127.0.0.1:54323
# Locally, DATABASE_URL and DIRECT_URL are the same.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# Production (Vercel + hosted Supabase):
#   DATABASE_URL = the TRANSACTION POOLER string (port 6543) + pgbouncer params, e.g.
#     postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
#   DIRECT_URL   = the DIRECT/session string (port 5432), used by `prisma db push`, e.g.
#     postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Both are on the Supabase dashboard under Connect -> ORMs (Prisma).

# ---- Generation harness (offline, Patrick's machine only) ----
# OPENROUTER_API_KEY="sk-or-..."

# ---- Auth (Clerk) ----
# Dev: pk_test_/sk_test_ keys from the Clerk dev instance.
# Production: pk_live_/sk_live_ keys from the Clerk PRODUCTION instance (created in the
# Clerk dashboard, requires the production domain + enabling GitHub/Google providers).
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
# CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# ---- Seeding ----
# Set to "false" when seeding PRODUCTION so the leaderboard starts with zero votes
# (dev default synthesizes demo votes so the UI has data).
# SEED_SYNTHETIC_VOTES=false
