# ---- Local dev (default) ----
# SQLite, no credentials. Just run `npm run setup`.
DATABASE_URL="file:./dev.db"

# ---- Production target (Supabase Postgres) ----
# Switch prisma/schema.prisma datasource provider to "postgresql", then:
# DATABASE_URL="postgresql://...supabase..."

# ---- Generation harness (offline, Patrick's machine only) ----
# OPENROUTER_API_KEY="sk-or-..."

# ---- Auth (production; Clerk free tier per PLAN.md) ----
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
# In dev, a cookie-based mock grader is used — no keys required.
